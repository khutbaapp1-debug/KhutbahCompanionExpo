{
  "expo": {
    "name": "KhutbahCompanionExpo",
    "slug": "KhutbahCompanionExpo",
    "version": "1.0.0",
    "scheme": "khutbahcompanion",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Khutbah Companion uses your location to calculate accurate prayer times for your area.",
        "NSMicrophoneUsageDescription": "Khutbah Companion uses your microphone to translate the khutbah live.",
        "NSUserTrackingUsageDescription": "Khutbah Companion uses your activity data to show relevant ads.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "WAKE_LOCK",
        "VIBRATE",
        "INTERNET",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB1S7ViAmw2BwniR7L4hbvO6b2LmIoM_F"
        }
      },
      "package": "com.khutbahcompanion.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E6F4FE"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Khutbah Companion uses your location to calculate accurate prayer times for your area."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6514143339893635~7248812544",
          "iosAppId": "ca-app-pub-6514143339893635~4866191788"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8412654f-a881-40ef-a82c-48546baddbf2"
      }
    }
  }
}
