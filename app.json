{
  "expo": {
    "name": "KhutbahCompanionExpo",
    "slug": "KhutbahCompanionExpo",
    "version": "1.0.0",
    "scheme": "khutbahcompanion",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Khutbah Companion uses your location to calculate accurate prayer times for your area.",
        "NSMicrophoneUsageDescription": "Khutbah Companion uses your microphone to translate the khutbah live."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["RECORD_AUDIO"],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "fonts": ["./assets/fonts/KFGQPCHafs.otf"],
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Khutbah Companion uses your location to calculate accurate prayer times for your area."
        }
      ]
    ]
  }
}
